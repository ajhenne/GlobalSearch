<GuiXml>
    <Controls>
        <TopLevelControl name="GS_Window" mouseEnabled="true" movable="true" hidden="true">
            <Dimensions x="500" y="600" />
            <Anchor point="CENTER" />
            
            <Controls>
                <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop" alpha="1">
                    <AnchorFill />
                </Backdrop>

                <Label name="$(parent)Header" font="ZoFontHeader3" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_SELECTED" text="GLOBAL SEARCH">
                    <Anchor point="TOPLEFT" offsetX="20" offsetY="15" />
                </Label>

                <Button name="$(parent)Close" inherits="ZO_CloseButton">
                    <Anchor point="TOPRIGHT" offsetX="-10" offsetY="10" />
                    <OnClicked>GlobalSearch.DisplayMenu()</OnClicked>
                </Button>

                <Control name="$(parent)Divider" inherits="ZO_WideHorizontalDivider">
                    <Anchor point="TOP" offsetY="50" />
                    <Dimensions x="460" />
                </Control>

                <Backdrop name="$(parent)SearchBG" inherits="ZO_EditBackdrop">
                    <Dimensions x="460" y="40" />
                    <Anchor point="TOP" offsetY="70" />
                    <Controls>
                        <EditBox name="GS_WindowSearchBar" inherits="ZO_DefaultEditForBackdrop" font="ZoFontWinH4" editEnabled="true" maxLetters="100">
                            <OnTextChanged>
                                GlobalSearch.OnSearchTextChanged(self)
                            </OnTextChanged>
                        </EditBox>
                    </Controls>
                </Backdrop>

                <Label name="$(parent)ResultsLabel" font="ZoFontHeader" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_DISABLED" text="RESULTS:">
                    <Anchor point="TOPLEFT" relativeTo="$(parent)SearchBG" relativePoint="BOTTOMLEFT" offsetY="20" />
                </Label>

                <Label name="GS_WindowOutput" font="ZoFontWinH3" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL" verticalAlignment="TOP">
                    <Dimensions x="460" y="400" />
                    <Anchor point="TOPLEFT" relativeTo="$(parent)ResultsLabel" relativePoint="BOTTOMLEFT" offsetY="10" />
                </Label>
            </Controls>
        </TopLevelControl>
    </Controls>
</GuiXml>